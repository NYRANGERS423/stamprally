{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash(npm run *)",
      "Bash(npm install *)",
      "Bash(npm ci *)",
      "Bash(npm test *)",
      "Bash(npx prisma *)",
      "Bash(npx tsc *)",
      "Bash(npx prettier *)",
      "Bash(npx create-next-app *)",
      "Bash(docker compose *)",
      "Bash(docker build *)",
      "Bash(docker run *)",
      "Bash(docker ps *)",
      "Bash(docker logs *)",
      "Bash(docker images *)",
      "Bash(git status*)",
      "Bash(git diff *)",
      "Bash(git log *)",
      "Bash(git add *)",
      "Bash(git commit *)",
      "Bash(git checkout *)",
      "Bash(git branch *)",
      "Bash(git pull *)",
      "Bash(git init*)",
      "Bash(git remote *)",
      "Bash(gh pr *)",
      "Bash(gh issue *)",
      "Bash(gh repo view *)",
      "Bash(gh repo create *)",
      "Bash(gh auth status*)"
    ],
    "ask": [
      "Bash(git push *)",
      "Bash(docker rm *)",
      "Bash(docker rmi *)",
      "Bash(docker volume rm *)",
      "Bash(rm -rf *)",
      "Bash(gh repo delete *)"
    ],
    "deny": [
      "Bash(sudo *)",
      "Bash(git push * --force*)",
      "Bash(git push * -f*)",
      "Bash(git push *--force-with-lease*)"
    ]
  }
}
