# Database
DATABASE_URL="postgresql://stamprally:stamprally_dev@localhost:5432/stamprally"

# App
NEXT_PUBLIC_APP_NAME="Stamprally"
APP_URL="http://localhost:3000"
APP_PORT="3000"

# Admin auth (env-var-based; no DB record)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="change-me-strong-pw"

# Session / auth secret
# Generate: openssl rand -base64 32
AUTH_SECRET="change-me-to-a-long-random-secret"

# Session cookie Secure flag. Unset = auto (true in production, false in dev).
# Set AUTH_COOKIE_SECURE=false when testing the production image over plain
# HTTP on a LAN IP — otherwise mobile browsers drop the cookie and login
# loops back to /login forever.
AUTH_COOKIE_SECURE=""

# Photo upload defaults (admin can override at runtime via DB)
UPLOAD_MAX_MB="5"
UPLOAD_OUTPUT_PX="800"
UPLOAD_OUTPUT_QUALITY="80"

# Postgres (used by docker compose)
POSTGRES_USER="stamprally"
POSTGRES_PASSWORD="stamprally_dev"
POSTGRES_DB="stamprally"

# Production-only: where the bind-mounted data lives on the host
# Defaults to ./data when unset (good for local prod-like tests).
# On Unraid, set this to your appdata path:
#   DATA_DIR=/mnt/user/appdata/stamprally
DATA_DIR=""

# Production-only: which image to run. Default pulls from GHCR.
# Set to "build:." for a local build, or pin a specific tag.
APP_IMAGE=""
PULL_POLICY=""
